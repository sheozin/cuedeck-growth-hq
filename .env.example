# CueDeck Growth HQ Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API Key (server-side only - used by /api/generate)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Note: REACT_APP_ prefixed variables are exposed to the browser
# Never put sensitive keys with this prefix
